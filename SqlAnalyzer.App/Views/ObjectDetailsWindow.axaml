<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SqlAnalyzer.App.Views.ObjectDetailsWindow"
        Width="980"
        Height="700"
        MinWidth="860"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="#F5F7FA">
  <Grid RowDefinitions="Auto,*,Auto">
    <Border Grid.Row="0" Background="#F9FBFD" BorderBrush="#D7DCE5" BorderThickness="0,0,0,1" Padding="16,14">
      <StackPanel Spacing="4">
        <TextBlock x:Name="TitleTextBlock" FontSize="18" FontWeight="SemiBold" Foreground="#1F2937"/>
        <TextBlock x:Name="SubtitleTextBlock" FontSize="11" Foreground="#64748B" TextWrapping="Wrap"/>
      </StackPanel>
    </Border>

    <TabControl Grid.Row="1" Margin="12">
      <TabItem x:Name="OverviewTabItem" Header="Overview">
        <ScrollViewer Margin="6">
          <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="10">
            <TextBlock x:Name="DisplayNameLabelTextBlock" Grid.Row="0" Grid.Column="0" Text="Display Name" FontWeight="SemiBold" Foreground="#334155"/>
            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="DisplayNameTextBlock" TextWrapping="Wrap"/>

            <TextBlock x:Name="RawNameLabelTextBlock" Grid.Row="1" Grid.Column="0" Text="Raw Name" FontWeight="SemiBold" Foreground="#334155"/>
            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="RawNameTextBlock" TextWrapping="Wrap"/>

            <TextBlock x:Name="SchemaLabelTextBlock" Grid.Row="2" Grid.Column="0" Text="Schema" FontWeight="SemiBold" Foreground="#334155"/>
            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="SchemaTextBlock" TextWrapping="Wrap"/>

            <TextBlock x:Name="TypeLabelTextBlock" Grid.Row="3" Grid.Column="0" Text="Type" FontWeight="SemiBold" Foreground="#334155"/>
            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TypeTextBlock" TextWrapping="Wrap"/>

            <TextBlock x:Name="ProviderLabelTextBlock" Grid.Row="4" Grid.Column="0" Text="Provider" FontWeight="SemiBold" Foreground="#334155"/>
            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="ProviderTextBlock" TextWrapping="Wrap"/>

            <TextBlock x:Name="DisplayTextLabelTextBlock" Grid.Row="5" Grid.Column="0" Text="Display Text" FontWeight="SemiBold" Foreground="#334155"/>
            <TextBlock Grid.Row="5" Grid.Column="1" x:Name="DisplayTextTextBlock" TextWrapping="Wrap"/>

            <TextBlock x:Name="DescriptionLabelTextBlock" Grid.Row="6" Grid.Column="0" Text="Description" FontWeight="SemiBold" Foreground="#334155"/>
            <TextBlock Grid.Row="6" Grid.Column="1" x:Name="DescriptionTextBlock" TextWrapping="Wrap"/>
          </Grid>
        </ScrollViewer>
      </TabItem>

      <TabItem x:Name="DdlTabItem" Header="DDL">
        <Grid Margin="6" RowDefinitions="Auto,*" RowSpacing="8">
          <TextBlock x:Name="DdlHintTextBlock" Foreground="#64748B" TextWrapping="Wrap"/>
          <TextBox Grid.Row="1"
                   x:Name="DdlTextBox"
                   AcceptsReturn="True"
                   IsReadOnly="True"
                   TextWrapping="Wrap"/>
        </Grid>
      </TabItem>

      <TabItem x:Name="PreviewSqlTabItem" Header="Preview SQL">
        <Grid Margin="6" RowDefinitions="Auto,*" RowSpacing="8">
          <TextBlock x:Name="PreviewHintTextBlock" Foreground="#64748B" TextWrapping="Wrap"/>
          <TextBox Grid.Row="1"
                   x:Name="PreviewSqlTextBox"
                   AcceptsReturn="True"
                   IsReadOnly="True"
                   TextWrapping="Wrap"/>
        </Grid>
      </TabItem>
    </TabControl>

    <Border Grid.Row="2" Background="#F9FBFD" BorderBrush="#D7DCE5" BorderThickness="0,1,0,0" Padding="12,10">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
        <Button x:Name="CloseButton" Content="Close" Click="CloseButton_Click"/>
      </StackPanel>
    </Border>
  </Grid>
</Window>
